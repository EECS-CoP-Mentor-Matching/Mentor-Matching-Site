rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isVerifiedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && (
          request.auth.token.email.matches('.*@oregonstate[.]edu')
          || request.auth.token.allowed == true
        );
    }

    // Allow anyone to read approved public reviews for the home page
    match /feedback/{feedbackId} {
      allow read: if resource.data.postedOnHomePage == true
                  && resource.data.publicConsent == true
                  && resource.data.feedbackType == 'Positive Review';
    }

    // pendingUsers: allow users to create their own pending record
    match /pendingUsers/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    // userProfile: write only to own profile or admin; read for verified users
    match /userProfile/{uid} {
      allow write: if request.auth != null
                   && (request.auth.uid == uid || isAdmin());
      allow read: if isVerifiedUser();
    }

    // messages: scoped per-field to prevent impersonation and limit visibility
    match /messages/{messageId} {
      // Only the real authenticated sender can create — senderUID must match auth UID
      allow create: if isVerifiedUser()
        && request.resource.data.senderUID == request.auth.uid;

      // Users can only read messages they sent or received; admins can read all
      allow read: if isAdmin()
        || (isVerifiedUser()
            && (resource.data.senderUID == request.auth.uid
                || resource.data.recipientUID == request.auth.uid));

      // Only the recipient can update, and only the mentorReply field
      // (mentor accepting/declining a connection request)
      allow update: if isAdmin()
        || (isVerifiedUser()
            && resource.data.recipientUID == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['mentorReply']));

      // Only the recipient can delete their own received messages; admins can delete any
      allow delete: if isAdmin()
        || (isVerifiedUser()
            && resource.data.recipientUID == request.auth.uid);
    }

    // Everything else: verified OSU users or approved non-OSU users, or admins
    match /{document=**} {
      allow read, write: if isVerifiedUser() || isAdmin();
    }

  }
}
